# ── STEM Academy — runtime environment ───────────────────────────────────────
# Copy this file to app.env and fill in all values before running.
# No variable substitution — all values must be complete literals.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (used by both the db and api containers) ──────────────────────
POSTGRES_DB=stemacademy
POSTGRES_USER=stemuser
POSTGRES_PASSWORD=replace_with_strong_password

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Copy POSTGRES_USER, POSTGRES_PASSWORD and POSTGRES_DB into the URL below
DATABASE_URL=postgres://stemuser:replace_with_strong_password@db:5432/stemacademy

# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_byte_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex

ANTHROPIC_API_KEY=sk-ant-...

# URL users type in their browser (must match your NPM proxy host domain)
CORS_ORIGIN=https://stemacademy.yourdomain.com

# ── Admin account (optional) ──────────────────────────────────────────────────
# If set, the API will create or promote this account to the admin role on every
# startup.  ADMIN_PASSWORD is only used when creating a brand-new account;
# it is ignored if the email already exists in the database.
ADMIN_EMAIL=admin@stemacademy.com
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_FNAME=Admin
